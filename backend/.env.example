PORT=5000
MONGO_URI=mongodb+srv://<db_username>:<db_password>@<cluster-address>.mongodb.net/tattoo-center?appName=Cluster0

# Comma-separated list if you need to allow more than one origin
# (e.g. your production Vercel domain + a preview deployment URL).
FRONTEND_URL=http://localhost:5173

ADMIN_KEY=your-secret-admin-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-too

PAYHERE_MERCHANT_ID=your-payhere-merchant-id
PAYHERE_MERCHANT_SECRET=your-payhere-merchant-secret
PAYHERE_SANDBOX=true
